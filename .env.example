# Copy this file to .env.local (or .env) and fill in your Supabase project values.
# Get these from your Supabase project dashboard → Settings → API.
#
# MOCK MODE: If both variables below are left unset (or the file is not created at all),
# the app starts in mock mode using in-memory sample data — no Supabase project required.
# This is useful for quickly testing the UI locally.
#
# To use a real Supabase project, uncomment and fill in both values:
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
